{
  "name": "star-owner",
  "productName": "星藏家",
  "version": "1.0.2",
  "dependencyReleaseVersion": "1.0.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "星藏家：Bilibili 收藏视频 Markdown 多 Agent 本地编排工作台。",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node scripts/setup-electron.js",
    "start": "electron .",
    "smoke": "node scripts/smoke-test.js",
    "test:rag": "node scripts/rag-assistant-test.js",
    "test:internal-agent": "node scripts/internal-agent-test.js",
    "test:task-attempt": "node scripts/task-attempt-test.js",
    "test:document-lifecycle": "node scripts/document-lifecycle-test.js",
    "test:video-cache": "node scripts/video-cache-test.js",
    "test:security": "node scripts/security-test.js",
    "test:image-clipboard": "node scripts/image-clipboard-test.js",
    "test:persistence": "node scripts/persistence-test.js",
    "test:collection-sync": "node scripts/collection-sync-test.js",
    "test:bili-client": "node scripts/bili-client-test.js",
    "test:asr-format": "node scripts/asr-format-test-runner.js",
    "test:media-edge": "node scripts/media-edge-cases-test.js",
    "test:analytics": "node scripts/analytics-test.js",
    "test:scheduler": "node scripts/resource-scheduler-test.js",
    "test:asr-service": "node scripts/asr-service-test.js",
    "test:knowledge-api": "node scripts/knowledge-api-test.js",
    "test:hardware": "node scripts/hardware-capabilities-test.js",
    "setup:asr": "powershell -ExecutionPolicy Bypass -File scripts/setup-faster-whisper.ps1",
    "verify:release": "powershell -ExecutionPolicy Bypass -File scripts/verify-release.ps1",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/build-portable-release.ps1 -ModelBundle all -SeparateModelAsset",
    "package:core": "powershell -ExecutionPolicy Bypass -File scripts/build-portable-release.ps1 -ModelBundle all -SeparateModelAsset -CoreOnly"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "electron": "^43.0.0",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.3.0",
    "mermaid": "^11.16.0",
    "pdf-parse": "^1.1.1",
    "sql.js": "^1.14.1"
  }
}
